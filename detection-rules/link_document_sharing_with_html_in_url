name: "Link: Document sharing with .html in url path"
description: "Detects messages containing document sharing language combined with suspicious links that use 'click here' type language and contain .html in the url path."
type: "rule"
severity: "medium"
source: |
  type.inbound
  // generic document sharing language
  and regex.icontains(body.current_thread.text,
                      '(share|invite|open).{0,20}(attachment|file|access|document)',
                      '(attachment|file|access|document|message).{0,10}(share|invite)'
  )
  // url contains "click me" language and ends with .html
  and any(filter(body.links,
                 regex.icontains(.display_text,
                                 'open|click|view|reveal|sign.{0,10}here'
                 )
          ),
          strings.iends_with(.href_url.url, '.html')
  )
  and not (subject.is_forward or subject.is_reply)
  and not any(ml.nlu_classifier(body.current_thread.text).topics,
              .name == "Newsletters and Digests" and .confidence != "low"
  )
attack_types:
  - "Credential Phishing"
tactics_and_techniques:
  - "Social engineering"
  - "Evasion"
  - "HTML smuggling"
detection_methods:
  - "Content analysis"
  - "URL analysis"
  - "Natural Language Understanding"
