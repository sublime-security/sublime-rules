name: "Attachment: RAR file with mismatched extension"
description: "Detects RAR archive files that have been given a different file extension, potentially to evade security controls or deceive recipients about the true file type."
type: "rule"
severity: "high"
source: |
  type.inbound
  and 0 < length(attachments) <= 3
  and any(attachments,
          .size > 0 and (.file_type == "rar" and .file_extension != "rar")
  )

attack_types:
  - "Malware/Ransomware"
tactics_and_techniques:
  - "Evasion"
detection_methods:
  - "Archive analysis"
  - "File analysis"
